{
  "manifest_version": 3,
  "name": "查找数据手册 (Look for Datasheet)",
  "version": "1.1.0",
  "description": "选中元器件型号后右键菜单快速跳转到 semiee.com 或 LCSC 查找数据手册",
  "permissions": [
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://www.semiee.com/*",
    "https://so.szlcsc.com/*",
    "https://item.szlcsc.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
